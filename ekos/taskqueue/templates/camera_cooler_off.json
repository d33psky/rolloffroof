            "category": "Camera",
            "supported_interfaces": [
                2
            ],
            "parameters": [],
            "actions": [
                {
                    "type": "SET",
                    "property": "CCD_COOLER",
                    "element": "COOLER_OFF",
                    "value": true,
                    "timeout": 30,
                    "retries": 2,
                    "failure_action": 1
                }
            ]
        }
    ]
